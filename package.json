{
  "name": "option-d-design-system",
  "version": "0.1.0",
  "description": "Option/D design system: framework-agnostic design tokens, CSS, and Tailwind preset. Zero runtime dependencies.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kaynshin/optiond-design-system.git"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/tokens.js",
  "types": "./dist/tokens.d.ts",
  "style": "dist/option-d.css",
  "exports": {
    ".": {
      "types": "./dist/tokens.d.ts",
      "default": "./dist/tokens.js"
    },
    "./css": "./dist/option-d.css",
    "./tailwind": "./dist/tailwind-preset.js",
    "./fonts/*": "./dist/fonts/*"
  },
  "scripts": {
    "build": "node build/style-dictionary.config.mjs && node build/copy-assets.mjs",
    "changeset": "changeset",
    "release": "npm run build && changeset publish",
    "storybook": "npm run build && storybook dev -p 6006",
    "build-storybook": "npm run build && storybook build -o storybook-static"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/html-vite": "^10.4.6",
    "storybook": "^10.4.6",
    "style-dictionary": "^4.4.0",
    "vite": "^8.1.3"
  },
  "homepage": "https://github.com/Kaynshin/optiond-design-system#readme",
  "bugs": {
    "url": "https://github.com/Kaynshin/optiond-design-system/issues"
  }
}
